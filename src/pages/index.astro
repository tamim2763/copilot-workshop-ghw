---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Mona Mayhem - GitHub Contribution Battle Arena</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap"
			rel="stylesheet"
		/>
		<style>
			:root {
				--bg-dark: #0a0a1a;
				--panel-dark: #10102a;
				--panel-border: rgba(143, 143, 202, 0.35);
				--neon-green: #5fed83;
				--neon-purple: #8a2be2;
				--text-main: #ecf0ff;
				--text-dim: #bcc5ec;
				--danger: #ff6f91;
				--neon-danger: #ff3366;
				--bg-glow-1: rgba(138, 43, 226, 0.2);
				--bg-glow-2: rgba(95, 237, 131, 0.18);
				--title-glow-primary: rgba(95, 237, 131, 0.9);
				--title-glow-secondary: rgba(138, 43, 226, 0.7);
				--panel-inset: rgba(95, 237, 131, 0.1);
				--panel-shadow: rgba(138, 43, 226, 0.15);
				--input-border: rgba(95, 237, 131, 0.6);
				--button-border: rgba(95, 237, 131, 0.85);
				--button-grad-1: rgba(95, 237, 131, 0.2);
				--button-grad-2: rgba(138, 43, 226, 0.3);
				--button-shadow: rgba(95, 237, 131, 0.35);
				--button-hover-shadow-1: rgba(95, 237, 131, 0.65);
				--button-hover-shadow-2: rgba(138, 43, 226, 0.5);
				--focus-shadow: rgba(95, 237, 131, 0.25);
				--card-border: rgba(138, 43, 226, 0.4);
				--vs-border: rgba(95, 237, 131, 0.8);
				--vs-grad-1: rgba(95, 237, 131, 0.22);
				--vs-grad-2: rgba(138, 43, 226, 0.24);
				--vs-shadow-1: rgba(95, 237, 131, 0.5);
				--vs-shadow-2: rgba(138, 43, 226, 0.45);
				--grid-border: rgba(95, 237, 131, 0.4);
				--cell-hover-1: rgba(95, 237, 131, 0.8);
				--cell-hover-2: rgba(138, 43, 226, 0.7);
				--loading-shadow-1: rgba(95, 237, 131, 0.85);
				--loading-shadow-2: rgba(138, 43, 226, 0.9);
				--label-shadow: rgba(95, 237, 131, 0.45);
				--focus-accent-1: rgba(138, 43, 226, 0.2);
				--focus-accent-2: rgba(138, 43, 226, 0.45);
				--focus-ring-glow: rgba(95, 237, 131, 0.6);
				--button-text-shadow: rgba(95, 237, 131, 0.7);
				--winner-shadow: rgba(95, 237, 131, 0.8);
			}

			body[data-theme='blaze'] {
				--neon-green: #00f5ff;
				--neon-purple: #ff6b35;
				--bg-glow-1: rgba(255, 107, 53, 0.22);
				--bg-glow-2: rgba(0, 245, 255, 0.2);
				--title-glow-primary: rgba(0, 245, 255, 0.9);
				--title-glow-secondary: rgba(255, 107, 53, 0.8);
				--panel-inset: rgba(0, 245, 255, 0.12);
				--panel-shadow: rgba(255, 107, 53, 0.2);
				--input-border: rgba(0, 245, 255, 0.65);
				--button-border: rgba(255, 107, 53, 0.85);
				--button-grad-1: rgba(0, 245, 255, 0.22);
				--button-grad-2: rgba(255, 107, 53, 0.32);
				--button-shadow: rgba(255, 107, 53, 0.35);
				--button-hover-shadow-1: rgba(0, 245, 255, 0.65);
				--button-hover-shadow-2: rgba(255, 107, 53, 0.6);
				--focus-shadow: rgba(255, 107, 53, 0.25);
				--card-border: rgba(255, 107, 53, 0.45);
				--vs-border: rgba(0, 245, 255, 0.82);
				--vs-grad-1: rgba(0, 245, 255, 0.24);
				--vs-grad-2: rgba(255, 107, 53, 0.25);
				--vs-shadow-1: rgba(0, 245, 255, 0.55);
				--vs-shadow-2: rgba(255, 107, 53, 0.5);
				--grid-border: rgba(0, 245, 255, 0.45);
				--cell-hover-1: rgba(0, 245, 255, 0.85);
				--cell-hover-2: rgba(255, 107, 53, 0.7);
				--loading-shadow-1: rgba(0, 245, 255, 0.85);
				--loading-shadow-2: rgba(255, 107, 53, 0.9);
				--label-shadow: rgba(0, 245, 255, 0.45);
				--focus-accent-1: rgba(255, 107, 53, 0.2);
				--focus-accent-2: rgba(255, 107, 53, 0.45);
				--focus-ring-glow: rgba(0, 245, 255, 0.6);
				--button-text-shadow: rgba(255, 107, 53, 0.7);
				--winner-shadow: rgba(0, 245, 255, 0.8);
			}

			body {
				margin: 0;
				padding: 2rem 1rem;
				background:
					radial-gradient(circle at 20% 20%, var(--bg-glow-1), transparent 35%),
					radial-gradient(circle at 80% 0%, var(--bg-glow-2), transparent 40%),
					var(--bg-dark);
				color: var(--text-main);
				font-family: 'Press Start 2P', monospace;
				font-size: 12px;
				line-height: 1.7;
				position: relative;
				min-height: 100vh;
			}

			body::before {
				content: '';
				position: fixed;
				inset: 0;
				pointer-events: none;
				z-index: 0;
				background: repeating-linear-gradient(
					to bottom,
					rgba(255, 255, 255, 0.04) 0px,
					rgba(255, 255, 255, 0.04) 1px,
					transparent 2px,
					transparent 4px
				);
				opacity: 0.35;
			}

			body::after {
				content: '';
				position: fixed;
				inset: 0;
				pointer-events: none;
				z-index: 0;
				background: radial-gradient(circle, transparent 40%, rgba(0, 0, 0, 0.55) 100%);
			}

			main {
				max-width: 64rem;
				margin: 0 auto;
				position: relative;
				z-index: 1;
			}

			h1 {
				margin: 0 0 0.5rem;
				font-size: clamp(1.25rem, 2.2vw, 1.75rem);
				color: var(--neon-green);
				text-shadow:
					0 0 4px var(--neon-green),
					0 0 10px var(--title-glow-primary),
					0 0 18px var(--title-glow-secondary);
				animation: neon-title-pulse 2.6s ease-in-out infinite;
			}

			p {
				margin: 0 0 1.5rem;
				color: var(--text-dim);
			}

			.panel {
				background: linear-gradient(160deg, rgba(21, 20, 47, 0.92), rgba(9, 9, 26, 0.9));
				border: 1px solid var(--panel-border);
				border-radius: 0.5rem;
				padding: 1.25rem;
				box-shadow:
					inset 0 0 0 1px var(--panel-inset),
					0 0 16px var(--panel-shadow);
			}

			form {
				display: grid;
				gap: 0.9rem;
			}

			label {
				display: grid;
				gap: 0.35rem;
				color: var(--neon-green);
				text-shadow: 0 0 6px var(--label-shadow);
			}

			.player-label {
				opacity: 0;
				transform: translateY(10px);
				animation: float-in 0.65s ease forwards;
			}

			form .player-label:nth-of-type(1) {
				animation-delay: 0.08s;
			}

			form .player-label:nth-of-type(2) {
				animation-delay: 0.16s;
			}

			.powerup-option {
				display: flex;
				align-items: center;
				gap: 0.55rem;
				padding: 0.2rem 0.1rem;
			}

			.powerup-option input[type='checkbox'] {
				width: 1rem;
				height: 1rem;
				accent-color: var(--neon-green);
				margin: 0;
			}

			.powerup-option label {
				display: inline;
				color: var(--text-dim);
				text-shadow: none;
				margin: 0;
			}

			input {
				padding: 0.6rem 0.7rem;
				border: 1px solid var(--input-border);
				border-radius: 0.35rem;
				background: rgba(4, 6, 21, 0.8);
				color: var(--text-main);
				font: inherit;
				transition: border-color 0.2s ease, box-shadow 0.2s ease;
			}

			input:focus {
				outline: none;
				border-color: var(--neon-purple);
				box-shadow:
					0 0 0 2px var(--focus-accent-1),
					0 0 14px var(--focus-accent-2);
			}

			input:focus-visible,
			button:focus-visible {
				outline: 2px solid var(--neon-green);
				outline-offset: 2px;
				box-shadow:
					0 0 0 2px var(--focus-shadow),
					0 0 14px var(--focus-ring-glow);
			}

			button {
				width: fit-content;
				padding: 0.6rem 1rem;
				border: 1px solid var(--button-border);
				background: linear-gradient(120deg, var(--button-grad-1), var(--button-grad-2));
				color: var(--text-main);
				border-radius: 0.35rem;
				cursor: pointer;
				text-shadow: 0 0 8px var(--button-text-shadow);
				box-shadow: 0 0 12px var(--button-shadow);
				opacity: 0;
				transform: translateY(10px);
				animation: float-in 0.65s ease forwards;
				animation-delay: 0.24s;
				transition: transform 0.2s ease, box-shadow 0.2s ease;
			}

			button:hover:not(:disabled) {
				transform: translateY(-1px);
				box-shadow:
					0 0 16px var(--button-hover-shadow-1),
					0 0 22px var(--button-hover-shadow-2);
			}

			button:disabled {
				opacity: 0.55;
				cursor: not-allowed;
			}

			.results {
				margin-top: 1rem;
				display: grid;
				gap: 0.5rem;
			}

			.theme-controls {
				margin-bottom: 1rem;
			}

			.theme-toggle {
				opacity: 1;
				transform: none;
				animation: none;
			}

			.status {
				color: var(--neon-green);
				min-height: 1.2rem;
			}

			.status.is-loading {
				animation: loading-shift 1s linear infinite;
			}

			.row {
				margin: 0;
			}

			.winner,
			.vs-badge {
				color: var(--neon-green);
				text-shadow: 0 0 8px var(--winner-shadow);
			}

			.error {
				color: var(--neon-danger);
				text-shadow:
					0 0 8px rgba(255, 51, 102, 0.92),
					0 0 16px rgba(255, 51, 102, 0.6);
				min-height: 1.2rem;
				padding: 0.2rem 0;
			}

			.error.has-message {
				padding: 0.55rem 0.65rem;
				border: 1px solid rgba(255, 51, 102, 0.7);
				border-radius: 0.35rem;
				background: rgba(255, 51, 102, 0.09);
				box-shadow:
					inset 0 0 8px rgba(255, 51, 102, 0.2),
					0 0 16px rgba(255, 51, 102, 0.28);
				animation: error-shake 0.32s ease-in-out;
			}

			.battle-board {
				display: none;
				grid-template-columns: 1fr auto 1fr;
				gap: 1rem;
				align-items: start;
			}

			.battle-board.visible {
				display: grid;
			}

			.player-card {
				display: grid;
				gap: 0.5rem;
				padding: 0.75rem;
				border: 1px solid var(--card-border);
				border-radius: 0.5rem;
				background: rgba(13, 15, 39, 0.8);
				position: relative;
				overflow: hidden;
			}

			.player-card::after {
				content: '';
				position: absolute;
				inset: -120% auto auto -120%;
				width: 160%;
				height: 260%;
				background: linear-gradient(
					120deg,
					transparent 35%,
					rgba(255, 255, 255, 0.16) 48%,
					transparent 62%
				);
				transform: translateX(0) rotate(12deg);
				animation: card-shimmer 4.8s linear infinite;
				pointer-events: none;
			}

			.player-meta {
				display: grid;
				gap: 0.15rem;
				margin: 0;
			}

			.vs-wrap {
				display: flex;
				align-items: center;
				justify-content: center;
				min-height: 100%;
			}

			.vs-badge {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				width: 2.4rem;
				height: 2.4rem;
				border: 1px solid var(--vs-border);
				border-radius: 999px;
				background: linear-gradient(135deg, var(--vs-grad-1), var(--vs-grad-2));
				box-shadow:
					0 0 12px var(--vs-shadow-1),
					0 0 16px var(--vs-shadow-2);
				animation: vs-gradient-shift 2.8s linear infinite;
			}

			.contrib-grid {
				display: grid;
				grid-auto-flow: column;
				grid-auto-columns: 0.9rem;
				gap: 2px;
				overflow-x: auto;
				padding: 0.45rem;
				border: 1px solid var(--grid-border);
				border-radius: 0.45rem;
				background: rgba(3, 6, 20, 0.85);
				min-height: 8rem;
			}

			:global(.week-column) {
				display: grid;
				grid-template-rows: repeat(7, 0.9rem);
				gap: 2px;
			}

			:global(.day-cell) {
				display: block;
				width: 0.9rem;
				height: 0.9rem;
				border-radius: 2px;
				background: #e5e7eb;
				border: 1px solid rgba(255, 255, 255, 0.1);
				transition: transform 0.12s ease, box-shadow 0.12s ease;
			}

			:global(.day-cell:hover) {
				transform: scale(1.22);
				box-shadow:
					0 0 8px var(--cell-hover-1),
					0 0 12px var(--cell-hover-2);
				position: relative;
				z-index: 2;
			}

			@media (max-width: 1024px) {
				.battle-board,
				.battle-board.visible {
					grid-template-columns: 1fr;
				}

				.vs-wrap {
					justify-content: flex-start;
				}
			}

			@media (max-width: 768px) {
				body {
					padding: 1.25rem 0.75rem;
					font-size: 10px;
				}

				h1 {
					font-size: 1.1rem;
				}

				p {
					margin-bottom: 1rem;
				}

				.panel {
					padding: 1rem;
				}

				form {
					gap: 0.7rem;
				}

				label {
					gap: 0.25rem;
				}

				button {
					width: 100%;
					text-align: center;
				}

				.results {
					gap: 0.4rem;
				}
			}

			@media (prefers-reduced-motion: reduce) {
				*,
				*::before,
				*::after {
					animation: none !important;
					transition: none !important;
				}
			}

			@keyframes neon-title-pulse {
				0%,
				100% {
					text-shadow:
						0 0 4px var(--neon-green),
						0 0 10px var(--title-glow-primary),
						0 0 18px var(--title-glow-secondary);
				}
				50% {
					text-shadow:
						0 0 6px var(--neon-green),
						0 0 15px var(--title-glow-primary),
						0 0 25px var(--title-glow-secondary);
				}
			}

			@keyframes vs-gradient-shift {
				0% {
					filter: hue-rotate(0deg);
				}
				100% {
					filter: hue-rotate(360deg);
				}
			}

			@keyframes card-shimmer {
				0% {
					transform: translateX(-55%) rotate(12deg);
				}
				100% {
					transform: translateX(180%) rotate(12deg);
				}
			}

			@keyframes float-in {
				to {
					opacity: 1;
					transform: translateY(0);
				}
			}

			@keyframes loading-shift {
				0%,
				100% {
					color: var(--neon-green);
					text-shadow: 0 0 8px var(--loading-shadow-1);
				}
				50% {
					color: var(--neon-purple);
					text-shadow: 0 0 8px var(--loading-shadow-2);
				}
			}

			@keyframes error-shake {
				0%,
				100% {
					transform: translateX(0);
				}
				20% {
					transform: translateX(-6px);
				}
				40% {
					transform: translateX(6px);
				}
				60% {
					transform: translateX(-4px);
				}
				80% {
					transform: translateX(4px);
				}
			}
		</style>
	</head>
	<body>
		<main>
			<h1>Mona Mayhem - GitHub Contribution Battle Arena</h1>
			<p>Enter two GitHub usernames and battle by total contributions.</p>
			<div class="theme-controls">
				<button
					id="theme-toggle"
					class="theme-toggle"
					type="button"
					aria-pressed="false"
					aria-label="Switch to blue and orange theme"
				>
					Theme: Retro Green/Purple
				</button>
			</div>

			<section class="panel">
				<form id="battle-form">
					<label for="player1" class="player-label">
						Player 1
						<input id="player1" name="player1" type="text" required autocomplete="off" />
					</label>
					<div class="powerup-option">
						<input id="player1-powerup" name="player1-powerup" type="checkbox" />
						<label for="player1-powerup">Player 1 Power-Up (+25%)</label>
					</div>

					<label for="player2" class="player-label">
						Player 2
						<input id="player2" name="player2" type="text" required autocomplete="off" />
					</label>
					<div class="powerup-option">
						<input id="player2-powerup" name="player2-powerup" type="checkbox" />
						<label for="player2-powerup">Player 2 Power-Up (+25%)</label>
					</div>

					<button id="battle-button" type="submit">Battle</button>
				</form>
			</section>

			<section class="panel results" aria-live="polite">
				<p id="status" class="status"></p>
				<div id="battle-board" class="battle-board">
					<article class="player-card">
						<p id="player1-meta" class="player-meta row"></p>
						<div id="player1-grid" class="contrib-grid"></div>
					</article>
					<div class="vs-wrap">
						<span class="vs-badge">VS</span>
					</div>
					<article class="player-card">
						<p id="player2-meta" class="player-meta row"></p>
						<div id="player2-grid" class="contrib-grid"></div>
					</article>
				</div>
				<p id="winner" class="row winner"></p>
				<p id="error" class="row error"></p>
			</section>
		</main>

		<script>
			interface ContributionDay {
				weekday: number;
				count: number;
				level: number;
			}

			interface ContributionWeek {
				index: number;
				first_day: string;
				contribution_days: ContributionDay[];
			}

			interface ContributionResponse {
				from: string;
				to: string;
				total_contributions: number;
				colors_full: string[];
				weeks: ContributionWeek[];
			}

			interface ApiErrorResponse {
				error?: {
					code?: string;
					message?: string;
				};
			}

			const form = document.querySelector<HTMLFormElement>('#battle-form')!;
			const themeToggleButton = document.querySelector<HTMLButtonElement>('#theme-toggle')!;
			const player1Input = document.querySelector<HTMLInputElement>('#player1')!;
			const player2Input = document.querySelector<HTMLInputElement>('#player2')!;
			const player1PowerUpInput = document.querySelector<HTMLInputElement>('#player1-powerup')!;
			const player2PowerUpInput = document.querySelector<HTMLInputElement>('#player2-powerup')!;
			const battleButton = document.querySelector<HTMLButtonElement>('#battle-button')!;
			const statusEl = document.querySelector<HTMLParagraphElement>('#status')!;
			const battleBoardEl = document.querySelector<HTMLDivElement>('#battle-board')!;
			const player1MetaEl = document.querySelector<HTMLParagraphElement>('#player1-meta')!;
			const player2MetaEl = document.querySelector<HTMLParagraphElement>('#player2-meta')!;
			const player1GridEl = document.querySelector<HTMLDivElement>('#player1-grid')!;
			const player2GridEl = document.querySelector<HTMLDivElement>('#player2-grid')!;
			const winnerEl = document.querySelector<HTMLParagraphElement>('#winner')!;
			const errorEl = document.querySelector<HTMLParagraphElement>('#error')!;
			const githubUsernamePattern = /^[a-z\d](?:[a-z\d]|-(?=[a-z\d])){0,38}$/i;
			const defaultTheme = 'default';
			const altTheme = 'blaze';
			const POWER_UP_MULTIPLIER = 1.25;

			const setTheme = (theme: string) => {
				const isAltTheme = theme === altTheme;
				document.body.dataset.theme = isAltTheme ? altTheme : defaultTheme;
				themeToggleButton.setAttribute('aria-pressed', String(isAltTheme));
				themeToggleButton.setAttribute(
					'aria-label',
					isAltTheme ? 'Switch to green and purple theme' : 'Switch to blue and orange theme',
				);
				themeToggleButton.textContent = isAltTheme
					? 'Theme: Neon Blue/Orange'
					: 'Theme: Retro Green/Purple';
			};

			const showError = (message: string) => {
				errorEl.textContent = message;
				errorEl.classList.remove('has-message');
				void errorEl.offsetWidth;
				errorEl.classList.add('has-message');
			};

			const validateUsernames = (player1: string, player2: string): string | null => {
				if (!player1 && !player2) {
					return 'Enter both GitHub usernames to start the battle.';
				}
				if (!player1) {
					return 'Player 1 username is missing. Please enter a GitHub username.';
				}
				if (!player2) {
					return 'Player 2 username is missing. Please enter a GitHub username.';
				}
				if (!githubUsernamePattern.test(player1) && !githubUsernamePattern.test(player2)) {
					return 'Both usernames look invalid. Use GitHub usernames with letters, numbers, or single hyphens.';
				}
				if (!githubUsernamePattern.test(player1)) {
					return 'Player 1 username is invalid. Use letters, numbers, or single hyphens only.';
				}
				if (!githubUsernamePattern.test(player2)) {
					return 'Player 2 username is invalid. Use letters, numbers, or single hyphens only.';
				}
				return null;
			};

			const clearResults = () => {
				battleBoardEl.classList.remove('visible');
				player1MetaEl.textContent = '';
				player2MetaEl.textContent = '';
				player1GridEl.innerHTML = '';
				player2GridEl.innerHTML = '';
				winnerEl.textContent = '';
				errorEl.textContent = '';
				errorEl.classList.remove('has-message');
			};

			const isContributionResponse = (payload: unknown): payload is ContributionResponse => {
				if (typeof payload !== 'object' || payload === null) return false;
				const data = payload as Partial<ContributionResponse>;
				return (
					typeof data.from === 'string' &&
					typeof data.to === 'string' &&
					typeof data.total_contributions === 'number' &&
					Array.isArray(data.colors_full) &&
					Array.isArray(data.weeks)
				);
			};

			const renderContributionGrid = (container: HTMLDivElement, data: ContributionResponse) => {
				container.innerHTML = '';
				const palette = ['#e5e7eb', '#9be9a8', '#40c463', '#30a14e', '#216e39'];
				const fragment = document.createDocumentFragment();

				for (const week of data.weeks) {
					const weekColumn = document.createElement('div');
					weekColumn.className = 'week-column';

					for (let dayIndex = 0; dayIndex < 7; dayIndex += 1) {
						const day = week.contribution_days[dayIndex];
						const cell = document.createElement('span');
						cell.className = 'day-cell';

						const level = typeof day?.level === 'number' ? Math.max(0, Math.min(4, day.level)) : 0;
						const count = typeof day?.count === 'number' ? day.count : 0;
						cell.style.backgroundColor = palette[level] ?? palette[0];
						cell.title = `${count} contributions`;
						weekColumn.append(cell);
					}

					fragment.append(weekColumn);
				}

				container.append(fragment);
			};

			const renderPlayer = (
				username: string,
				data: ContributionResponse,
				powerUpActive: boolean,
				effectiveTotal: number,
				metaEl: HTMLParagraphElement,
				gridEl: HTMLDivElement,
			) => {
				const powerUpLabel = powerUpActive
					? `<span>Power-Up Active x${POWER_UP_MULTIPLIER.toFixed(2)}: ${effectiveTotal}</span>`
					: '<span>Power-Up: Off</span>';
				const totalLabel = powerUpActive
					? `<span>Base Total: ${data.total_contributions}</span>`
					: `<span>Total: ${effectiveTotal}</span>`;
				metaEl.innerHTML = `<strong>${username}</strong>${totalLabel}${powerUpLabel}<span>Range: ${data.from} to ${data.to}</span>`;
				renderContributionGrid(gridEl, data);
			};

			const getEffectiveTotal = (baseTotal: number, powerUpActive: boolean): number =>
				powerUpActive ? Math.round(baseTotal * POWER_UP_MULTIPLIER) : baseTotal;

			const fetchContributions = async (username: string): Promise<ContributionResponse> => {
				const response = await fetch(`/api/contributions/${encodeURIComponent(username)}`);
				let payload: unknown = null;

				try {
					payload = await response.json();
				} catch {
					throw new Error('Could not read contributions response.');
				}

				if (!response.ok) {
					const message = (payload as ApiErrorResponse)?.error?.message;
					throw new Error(typeof message === 'string' ? message : 'Failed to fetch contributions.');
				}

				if (!isContributionResponse(payload)) {
					throw new Error('Unexpected contributions payload format.');
				}

				return payload;
			};

			form.addEventListener('submit', async (event) => {
				event.preventDefault();
				clearResults();
				statusEl.textContent = '';
				statusEl.classList.remove('is-loading');

				const player1 = player1Input.value.trim();
				const player2 = player2Input.value.trim();
				const player1PowerUpActive = player1PowerUpInput.checked;
				const player2PowerUpActive = player2PowerUpInput.checked;

				const validationError = validateUsernames(player1, player2);
				if (validationError) {
					showError(validationError);
					return;
				}

				if (player1.toLowerCase() === player2.toLowerCase()) {
					showError('Use two different usernames so each player can battle.');
					return;
				}

				battleButton.disabled = true;
				battleButton.textContent = 'Battling...';
				statusEl.textContent = 'Battling...';
				statusEl.classList.add('is-loading');

				try {
					const [player1Data, player2Data] = await Promise.all([
						fetchContributions(player1),
						fetchContributions(player2),
					]);

					const player1EffectiveTotal = getEffectiveTotal(
						player1Data.total_contributions,
						player1PowerUpActive,
					);
					const player2EffectiveTotal = getEffectiveTotal(
						player2Data.total_contributions,
						player2PowerUpActive,
					);

					renderPlayer(
						player1,
						player1Data,
						player1PowerUpActive,
						player1EffectiveTotal,
						player1MetaEl,
						player1GridEl,
					);
					renderPlayer(
						player2,
						player2Data,
						player2PowerUpActive,
						player2EffectiveTotal,
						player2MetaEl,
						player2GridEl,
					);
					battleBoardEl.classList.add('visible');

					if (player1EffectiveTotal === player2EffectiveTotal) {
						winnerEl.textContent = 'Result: It is a tie!';
					} else {
						const winnerName = player1EffectiveTotal > player2EffectiveTotal ? player1 : player2;
						winnerEl.textContent = `Winner: ${winnerName}`;
					}

					statusEl.textContent = 'Battle complete.';
					statusEl.classList.remove('is-loading');
				} catch (error) {
					const message = error instanceof Error ? error.message : 'Battle failed. Please try again.';
					showError(message);
					statusEl.textContent = '';
					statusEl.classList.remove('is-loading');
				} finally {
					battleButton.disabled = false;
					battleButton.textContent = 'Battle';
				}
			});

			const submitOnEnter = (event: KeyboardEvent) => {
				if (event.key !== 'Enter') return;
				if (battleButton.disabled) return;
				event.preventDefault();
				form.requestSubmit();
			};

			player1Input.addEventListener('keydown', submitOnEnter);
			player2Input.addEventListener('keydown', submitOnEnter);
			themeToggleButton.addEventListener('click', () => {
				const nextTheme = document.body.dataset.theme === altTheme ? defaultTheme : altTheme;
				setTheme(nextTheme);
			});
			setTheme(defaultTheme);
		</script>
	</body>
</html>
